# POSTGRES_URL or DATABASE_URL: when set, lib/services/repositories.ts uses
# the real Postgres (Neon) backend in lib/db/* instead of the in-memory
# mock. Vercel injects POSTGRES_URL automatically once a Neon database is
# attached to the project (Storage tab) -- no manual setup needed there.
POSTGRES_URL=
