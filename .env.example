NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=
APP_ORIGIN=
DEMO_LOGIN_EMAIL=
DEMO_LOGIN_PASSWORD=
# Required in production: HMAC-SHA256 signing secret for the session cookie
# (lib/mock/auth-adapter.ts). Missing this in production throws at module
# load rather than silently signing cookies with the dev-only fallback.
SESSION_SECRET=
# Required in production: AES-256-GCM key for encrypting secret-bearing
# cookies at rest (the `saved_accounts` cookie holds Supabase refresh tokens
# -- lib/server/cookie-crypto.ts). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Missing this in production throws rather than encrypting with the dev fallback.
COOKIE_SECRET=
DATA_BACKEND=mock
# POSTGRES_URL or DATABASE_URL: when set, lib/services/repositories.ts uses
# the real Postgres (Neon) backend in lib/db/* instead of the in-memory
# mock. Vercel injects POSTGRES_URL automatically once a Neon database is
# attached to the project (Storage tab) -- no manual setup needed there.
POSTGRES_URL=
# Non-pooled (direct) connection used ONLY by build-time migrations (node-pg-migrate
# over pg/TCP; avoids pgbouncer DDL issues). Runtime uses the pooled POSTGRES_URL above.
DATABASE_URL_UNPOOLED=
POSTGRES_URL_NON_POOLING=
